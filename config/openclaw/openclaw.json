{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 2470,
    "trustedProxies": ["127.0.0.1", "::1"],
    "controlUi": {
      "allowedOrigins": ["https://netty.harivan.sh"]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "skipBootstrap": true,
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "sandbox": {
        "mode": "non-main"
      }
    }
  },
  "tools": {
    "profile": "coding",
    "fs": {
      "workspaceOnly": true
    },
    "loopDetection": {
      "enabled": true
    },
    "deny": ["sessions_send", "sessions_spawn"]
  }
}
