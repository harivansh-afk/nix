#!/bin/bash
# SketchyBar rc, linked at ~/.config/sketchybar/sketchybarrc. Cozybox
# floating layout: the bar itself is fully transparent (no painted strip),
# only the items carry a background - soft rounded blocks, no borders.
# Left: one floating tab per aerospace workspace (number + one app icon
# glyph, focused tab in the accent). Right: floating resource and status blocks.
# The notch keeps the two sections apart; nothing is placed in the middle.
# Colors come from themes/current, a symlink managed by the `theme` script
# (rendered per-mode from lib/theme.nix).

source "$CONFIG_DIR/themes/current"

PLUGIN_DIR="$CONFIG_DIR/plugins"
FONT="Berkeley Mono"
APP_FONT="sketchybar-app-font"

# Height of the notch strip: NSScreen.safeAreaInsets.top at the current
# scaled resolution (2048x1330 on the built-in display). Re-measure with:
#   swift -e 'import AppKit; print(NSScreen.main!.safeAreaInsets.top)'
BAR_HEIGHT=43

# MARGIN is the air around the floating blocks: the item height and the bar
# edge padding both derive from it so the gap is identical top, bottom, left
# and right (43 - 2*6 = 31).
MARGIN=6
ITEM_HEIGHT=$((BAR_HEIGHT - 2 * MARGIN))

# --- spacing scale (pt): every gap in the bar derives from these ---
# PAD_EDGE   inside a block at its outer edges (also glyphless-tab padding,
#            mirrored in plugins/spaces.sh - keep them in sync)
# PAD_ITEM   each side of a component boundary in the right block (gap = 2x)
# PAD_TIGHT  between a muted prefix (vol/bat) and its value (gap = 2x)
# TAB_GAP    between workspace tabs
PAD_EDGE=14
PAD_ITEM=9
PAD_TIGHT=4
TAB_GAP=6

sketchybar --bar \
  position=top \
  height=$BAR_HEIGHT \
  color=0x00000000 \
  corner_radius=0 \
  margin=0 \
  y_offset=0 \
  padding_left=$MARGIN \
  padding_right=$MARGIN \
  display=all \
  sticky=on

# corner_radius 13 was calibrated by eye against the physical display corner
# curve (Apple does not publish the radius and no API exposes it on macOS).
# Blocks paint the main cozybox background (BAR_COLOR, #101010 dark), darker
# than the surface tone - user preference.
sketchybar --default \
  background.drawing=off \
  background.color="$BAR_COLOR" \
  background.corner_radius=13 \
  background.height=$ITEM_HEIGHT \
  background.border_width=0 \
  icon.drawing=off \
  icon.font="$FONT:Regular:13.0" \
  icon.color="$MUTED_COLOR" \
  icon.padding_left=$PAD_ITEM \
  icon.padding_right=$PAD_TIGHT \
  label.font="$FONT:Regular:13.0" \
  label.color="$TEXT_COLOR" \
  label.padding_left=$PAD_TIGHT \
  label.padding_right=$PAD_ITEM

# --- left section: floating workspace tabs ---
# Static shells only; plugins/spaces.sh renders all of them in one batch per
# event (one process per event instead of one per workspace - keeps it fast).
sketchybar --add event aerospace_workspace_change

for sid in $(aerospace list-workspaces --all); do
  # tab internals are visually compensated for font side bearings (digits
  # render ~2pt inside their advance, the app glyphs ~1pt): 10/11/10 makes
  # all three gaps measure ~12pt on screen (verified by pixel measurement);
  # plugins/spaces.sh mirrors these numbers - keep them in sync
  sketchybar --add item "space.$sid" left \
    --set "space.$sid" \
    drawing=off \
    background.drawing=on \
    padding_left=0 \
    padding_right=$TAB_GAP \
    icon.drawing=on \
    icon="$sid" \
    icon.padding_left=10 \
    icon.padding_right=11 \
    label.font="$APP_FONT:Regular:15.0" \
    label.drawing=off \
    label.padding_left=0 \
    label.padding_right=10 \
    click_script="aerospace workspace $sid"
done

sketchybar --add item spaces_monitor left \
  --subscribe spaces_monitor aerospace_workspace_change front_app_switched system_woke \
  --set spaces_monitor \
  drawing=off \
  script="$PLUGIN_DIR/spaces.sh"

# --- right section: one floating block, spacing instead of separators:
# volume | battery | clock ---
# (items added rightmost-first, grouped by a bracket that paints the
# shared background)
# icon = date (normal text color), label = time (pink)
sketchybar --add item clock right \
  --subscribe clock system_woke \
  --set clock \
  update_freq=10 \
  icon.drawing=on \
  icon.color="$TEXT_COLOR" \
  icon.padding_left=$PAD_ITEM \
  icon.padding_right=$PAD_TIGHT \
  label.color="$PINK_COLOR" \
  label.padding_left=$PAD_TIGHT \
  label.padding_right=$PAD_EDGE \
  click_script="open -a Calendar" \
  script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
  --subscribe battery power_source_change system_woke \
  --set battery \
  update_freq=60 \
  icon.drawing=on \
  icon=bat \
  icon.padding_left=$PAD_ITEM \
  icon.padding_right=$PAD_TIGHT \
  label.font="$FONT:Bold:13.0" \
  label.padding_left=$PAD_TIGHT \
  label.padding_right=$PAD_ITEM \
  click_script='open "x-apple.systempreferences:com.apple.Battery-Settings.extension"' \
  script="$PLUGIN_DIR/battery.sh"

sketchybar --add item volume right \
  --subscribe volume volume_change mouse.clicked mouse.scrolled \
  --set volume \
  icon.drawing=on \
  icon=vol \
  icon.padding_left=$PAD_EDGE \
  icon.padding_right=$PAD_TIGHT \
  label.padding_left=$PAD_TIGHT \
  label.padding_right=$PAD_ITEM \
  script="$PLUGIN_DIR/volume.sh"

sketchybar --add bracket status \
  clock battery volume \
  --set status background.drawing=on

# --- resources: a separate block immediately left of status ---
sketchybar --add item cpu right \
  --set cpu \
  update_freq=5 \
  padding_right=$TAB_GAP \
  icon.drawing=on \
  icon=cpu \
  icon.padding_left=$PAD_ITEM \
  icon.padding_right=$PAD_TIGHT \
  label.padding_left=$PAD_TIGHT \
  label.padding_right=$PAD_EDGE \
  script="$PLUGIN_DIR/stats.sh"

sketchybar --add item memory right \
  --set memory \
  icon.drawing=on \
  icon=mem \
  icon.padding_left=$PAD_EDGE \
  icon.padding_right=$PAD_TIGHT \
  label.padding_left=$PAD_TIGHT \
  label.padding_right=$PAD_ITEM

sketchybar --add bracket resources \
  cpu memory \
  --set resources background.drawing=on

# --- init ---
sketchybar --update
sketchybar --trigger aerospace_workspace_change \
  FOCUSED_WORKSPACE="$(aerospace list-workspaces --focused)"
