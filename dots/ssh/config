# SSH client config, linked at ~/.ssh/config. Live-edited.

Host aurelius
  HostName 100.71.160.102
  User nixos
  IdentityFile ~/.ssh/id_ed25519

Host spark
  HostName spark-ix
  HostKeyAlias spark
  User rathi
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
  ForwardAgent yes
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h:%p
  ControlPersist 10m
  ServerAliveInterval 60
  ServerAliveCountMax 3

Host spark-lan
  HostName 192.168.0.6
