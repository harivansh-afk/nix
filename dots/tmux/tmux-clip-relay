#!/usr/bin/env bash
# OSC 52 relay invoked by the copy-mode bindings in tmux.conf. Reads piped
# copy-mode text, falling back to the current tmux paste buffer for older
# callers, and writes OSC 52 directly to the connected client's TTY. Linked at
# ~/.local/bin/tmux-clip-relay.
set -euo pipefail
client_tty="$(tmux display-message -p '#{client_tty}')"
[ -n "$client_tty" ] || exit 0
if [ -t 0 ]; then
  data="$(tmux save-buffer - | base64 | tr -d '\n')"
else
  data="$(base64 | tr -d '\n')"
  if [ -z "$data" ]; then
    data="$(tmux save-buffer - | base64 | tr -d '\n')"
  fi
fi
[ -n "$data" ] || exit 0
printf '\033]52;c;%s\a' "$data" >"$client_tty"
