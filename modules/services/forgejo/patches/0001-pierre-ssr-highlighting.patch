+++ b/services/gitdiff/pierre.go
@@ -0,0 +1,275 @@
+// Copyright 2026 The Forgejo Authors. All rights reserved.
+// SPDX-License-Identifier: MIT
+
+package gitdiff
+
+import (
+	"bytes"
+	"context"
+	"crypto/sha256"
+	"encoding/json"
+	"fmt"
+	"html/template"
+	"io"
+	"net"
+	"net/http"
+	"os"
+	"strings"
+	"sync"
+	"time"
+	"unicode/utf8"
+)
+
+const (
+	pierreRenderTimeout   = 5 * time.Second
+	pierreTokenizeTimeout = 200 * time.Millisecond
+)
+
+type pierreTokenizeRequest struct {
+	FileName string `json:"fileName"`
+	Language string `json:"language"`
+	Code     string `json:"code"`
+	Theme    string `json:"theme"`
+}
+
+type pierreTokenizeResponse struct {
+	HTML  string   `json:"html"`
+	Lines []string `json:"lines"`
+}
+
+type pierreRenderRequest struct {
+	Patch string `json:"patch"`
+	Split bool   `json:"split"`
+	Theme string `json:"theme"`
+}
+
+type pierreRenderResponse struct {
+	HTML string `json:"html"`
+}
+
+var (
+	pierreClientMu     sync.Mutex
+	pierreClientSocket string
+	pierreClient       *http.Client
+)
+
+func getPierreClient(socketPath string) *http.Client {
+	pierreClientMu.Lock()
+	defer pierreClientMu.Unlock()
+
+	if pierreClient != nil && pierreClientSocket == socketPath {
+		return pierreClient
+	}
+
+	dialer := &net.Dialer{Timeout: pierreTokenizeTimeout}
+	pierreClientSocket = socketPath
+	pierreClient = &http.Client{
+		Transport: &http.Transport{
+			DialContext: func(ctx context.Context, _, _ string) (net.Conn, error) {
+				return dialer.DialContext(ctx, "unix", socketPath)
+			},
+		},
+	}
+	return pierreClient
+}
+
+func pierreSocketPath() string {
+	return os.Getenv("PIERRE_SSR_SOCKET")
+}
+
+func pierreTokenize(fileName, language, code string) (template.HTML, bool) {
+	if code == "" || code == "\n" || !utf8.ValidString(code) {
+		return "", false
+	}
+
+	response, ok := pierreTokenizeRaw(fileName, language, code)
+	if !ok || response.HTML == "" {
+		return "", false
+	}
+	return template.HTML(response.HTML), true
+}
+
+// PierreFile returns syntax-highlighted HTML lines using the Pierre sidecar.
+func PierreFile(fileName, language string, code []byte) ([]template.HTML, string, bool) {
+	if len(code) == 0 || !utf8.Valid(code) {
+		return nil, "", false
+	}
+
+	response, ok := pierreTokenizeRaw(fileName, language, string(code))
+	if !ok || len(response.Lines) == 0 {
+		return nil, "", false
+	}
+
+	lines := make([]template.HTML, 0, len(response.Lines))
+	for _, line := range response.Lines {
+		lines = append(lines, template.HTML(line))
+	}
+	return lines, language, true
+}
+
+// PierreDiff returns a server-rendered Pierre diff for a Forgejo diff file.
+func PierreDiff(file *DiffFile, isSplit bool, theme string) template.HTML {
+	if file == nil || file.IsBin || file.IsIncomplete || file.IsSubmodule {
+		return ""
+	}
+
+	patch := buildPierrePatch(file)
+	if patch == "" {
+		return ""
+	}
+
+	html, ok := pierreRender(patch, isSplit, theme)
+	if !ok {
+		return ""
+	}
+	return html
+}
+
+func buildPierrePatch(file *DiffFile) string {
+	oldName := file.OldName
+	if oldName == "" {
+		oldName = file.Name
+	}
+	newName := file.Name
+	if newName == "" {
+		newName = oldName
+	}
+	if oldName == "" && newName == "" {
+		return ""
+	}
+
+	var builder strings.Builder
+	builder.WriteString("diff --git a/")
+	builder.WriteString(oldName)
+	builder.WriteString(" b/")
+	builder.WriteString(newName)
+	builder.WriteByte('\n')
+	switch {
+	case file.IsCreated:
+		builder.WriteString("--- /dev/null\n+++ b/")
+		builder.WriteString(newName)
+		builder.WriteByte('\n')
+	case file.IsDeleted:
+		builder.WriteString("--- a/")
+		builder.WriteString(oldName)
+		builder.WriteString("\n+++ /dev/null\n")
+	default:
+		builder.WriteString("--- a/")
+		builder.WriteString(oldName)
+		builder.WriteString("\n+++ b/")
+		builder.WriteString(newName)
+		builder.WriteByte('\n')
+	}
+
+	for _, section := range file.Sections {
+		if section.Name != "" {
+			builder.WriteString(section.Name)
+			if !strings.HasSuffix(section.Name, "\n") {
+				builder.WriteByte('\n')
+			}
+		}
+		for _, line := range section.Lines {
+			if line == nil || line.Content == "" {
+				continue
+			}
+			builder.WriteString(line.Content)
+			if !strings.HasSuffix(line.Content, "\n") {
+				builder.WriteByte('\n')
+			}
+		}
+	}
+
+	return builder.String()
+}
+
+func pierreRender(patch string, isSplit bool, theme string) (template.HTML, bool) {
+	socketPath := pierreSocketPath()
+	if socketPath == "" || patch == "" || !utf8.ValidString(patch) {
+		return "", false
+	}
+
+	payload, err := json.Marshal(pierreRenderRequest{Patch: patch, Split: isSplit, Theme: theme})
+	if err != nil {
+		return "", false
+	}
+
+	ctx, cancel := context.WithTimeout(context.Background(), pierreRenderTimeout)
+	defer cancel()
+
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, "http://pierre-ssr/render", bytes.NewReader(payload))
+	if err != nil {
+		return "", false
+	}
+	req.Header.Set("Content-Type", "application/json")
+	req.Header.Set("Idempotency-Key", pierreRequestKey("diff", fmt.Sprintf("%t", isSplit), theme, patch))
+
+	resp, err := getPierreClient(socketPath).Do(req)
+	if err != nil {
+		return "", false
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode != http.StatusOK {
+		return "", false
+	}
+
+	body, err := io.ReadAll(resp.Body)
+	if err != nil {
+		return "", false
+	}
+
+	var out pierreRenderResponse
+	if err := json.Unmarshal(body, &out); err != nil {
+		return "", false
+	}
+	if out.HTML == "" {
+		return "", false
+	}
+	return template.HTML(out.HTML), true
+}
+
+func pierreTokenizeRaw(fileName, language, code string) (*pierreTokenizeResponse, bool) {
+	socketPath := pierreSocketPath()
+	if socketPath == "" {
+		return nil, false
+	}
+
+	payload, err := json.Marshal(pierreTokenizeRequest{
+		FileName: fileName,
+		Language: language,
+		Code:     code,
+		Theme:    "system",
+	})
+	if err != nil {
+		return nil, false
+	}
+
+	ctx, cancel := context.WithTimeout(context.Background(), pierreTokenizeTimeout)
+	defer cancel()
+
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, "http://pierre-ssr/tokenize", bytes.NewReader(payload))
+	if err != nil {
+		return nil, false
+	}
+	req.Header.Set("Content-Type", "application/json")
+	req.Header.Set("Idempotency-Key", pierreRequestKey(fileName, language, code))
+
+	resp, err := getPierreClient(socketPath).Do(req)
+	if err != nil {
+		return nil, false
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode != http.StatusOK {
+		return nil, false
+	}
+
+	var out pierreTokenizeResponse
+	if err := json.NewDecoder(resp.Body).Decode(&out); err != nil {
+		return nil, false
+	}
+	return &out, true
+}
+
+func pierreRequestKey(parts ...string) string {
+	sum := sha256.Sum256([]byte(strings.Join(parts, "\x00")))
+	return fmt.Sprintf("%x", sum[:])
+}
